# OpenRouter API key (for AI story/illustration generation)
# Can be set here OR configured through the app's setup wizard
OPENROUTER_API_KEY=

# Auth mode: "local" (default, in-app password) or "external" (skip, for reverse proxy auth)
# AUTH_MODE=local

# Server port (default: 3000)
# PORT=3000

# Data directory (default: ./server/data)
# DATA_DIR=./server/data
